PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DB_NAME

# Use a long random secret in production.
JWT_SECRET=replace_with_a_long_random_secret

# Comma-separated frontend origins allowed by CORS.
CLIENT_URL=https://your-frontend-domain.vercel.app

# Email credentials for verification emails.
EMAIL_USER=you@example.com
EMAIL_PASS=your_email_app_password

# Separate hosted execution service URL.
EXECUTION_SERVICE_URL=https://your-execution-service.onrender.com/execute

# Production AI:
# - gemini: hosted free tier from Google AI Studio, limited quota
# - openai: hosted paid/free-credit depending on your account
# - disabled: clean UI with AI turned off
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local development only. Do not use Ollama in deployed production unless you
# deploy Ollama on a server yourself.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
