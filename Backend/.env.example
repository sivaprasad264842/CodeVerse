PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string.
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/topcoders

# Use a long random secret in production.
JWT_SECRET=replace_with_a_long_random_secret

# Comma-separated frontend origins allowed by CORS.
CLIENT_URL=https://topcoders.com,https://www.topcoders.com

# Email credentials for verification emails.
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# Separate hosted execution service URL.
EXECUTION_SERVICE_URL=http://runner:5001/execute

# OpenAI code analysis.
OPENAI_API_KEY=sk-replace_me
OPENAI_MODEL=gpt-4o-mini

